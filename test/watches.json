{
  "info": {
    "name": "CastellanStore - Catalog API",
    "description": "Endpoints públicos del catálogo: listar relojes, destacados, detalle por ID."
  },
  "item": [
    {
      "name": "Obtener todos los relojes (paginado)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Listado de relojes', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const paginatedSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"data\", \"totalItems\", \"totalPages\"],",
              "      \"properties\": {",
              "        \"data\": { \"type\": \"array\", \"minItems\": 1 },",
              "        \"totalItems\": { \"type\": \"number\" },",
              "        \"totalPages\": { \"type\": \"number\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de listado paginado es válido', () => {",
              "  pm.expect(tv4.validate(json, paginatedSchema)).to.be.true;",
              "});",
              "pm.environment.set('watchId', json.data.data[0]._id);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/watches?page=0&size=12",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "watches"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "12" }
          ]
        }
      }
    },
    {
      "name": "Obtener relojes destacados",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Destacados', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const arraySchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": { \"type\": \"array\" }",
              "  }",
              "};",
              "pm.test('El esquema de destacados es válido', () => {",
              "  pm.expect(tv4.validate(json, arraySchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/watches/featured",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "watches", "featured"]
        }
      }
    },
    {
      "name": "Obtener reloj por ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Detalle del reloj', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const detailSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"_id\", \"name\", \"price\"],",
              "      \"properties\": {",
              "        \"_id\": { \"type\": \"string\" },",
              "        \"name\": { \"type\": \"string\" },",
              "        \"price\": { \"type\": \"number\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema del detalle es válido', () => {",
              "  pm.expect(tv4.validate(json, detailSchema)).to.be.true;",
              "});",
              "pm.expect(json.data._id).to.eql(pm.environment.get('watchId'));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/watches/{{watchId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "watches", "{{watchId}}"]
        }
      }
    },
    {
      "name": "Error: Reloj no encontrado",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404 - Reloj no encontrado', () => { pm.response.to.have.status(404); });",
              "const json = pm.response.json();",
              "const errorSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [false] }",
              "  }",
              "};",
              "pm.test('El esquema de error 404 es válido', () => {",
              "  pm.expect(tv4.validate(json, errorSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/watches/000000000000000000000000",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "watches", "000000000000000000000000"]
        }
      }
    },
    {
      "name": "Error: ID de reloj inválido",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 - ID inválido', () => { pm.response.to.have.status(400); });",
              "const json = pm.response.json();",
              "const errorSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [false] }",
              "  }",
              "};",
              "pm.test('El esquema de error 400 es válido', () => {",
              "  pm.expect(tv4.validate(json, errorSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/watches/id-invalido",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "watches", "id-invalido"]
        }
      }
    },
    {
      "name": "Buscar relojes por nombre",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Búsqueda', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const searchSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"data\"],",
              "      \"properties\": {",
              "        \"data\": { \"type\": \"array\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de búsqueda es válido', () => {",
              "  pm.expect(tv4.validate(json, searchSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/watches?search=Classic&page=0&size=12",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "watches"],
          "query": [
            { "key": "search", "value": "Classic" },
            { "key": "page", "value": "0" },
            { "key": "size", "value": "12" }
          ]
        }
      }
    }
  ]
}
