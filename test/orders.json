{
  "info": {
    "name": "CastellanStore - Orders API",
    "description": "Endpoints de pedidos: crear pedido, listar pedidos del usuario (requieren autenticación)."
  },
  "item": [
    {
      "name": "Crear pedido desde carrito",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 - Pedido creado', () => { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "const orderSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"_id\", \"orderNumber\", \"status\"],",
              "      \"properties\": {",
              "        \"_id\": { \"type\": \"string\" },",
              "        \"orderNumber\": { \"type\": \"string\" },",
              "        \"status\": { \"type\": \"string\", \"enum\": [\"confirmed\"] }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema del pedido es válido', () => {",
              "  pm.expect(tv4.validate(json, orderSchema)).to.be.true;",
              "});",
              "pm.environment.set('orderId', json.data._id);",
              "pm.environment.set('orderNumber', json.data.orderNumber);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    {\n      \"watchId\": \"{{watchId}}\",\n      \"name\": \"Reloj de prueba\",\n      \"price\": 199.99,\n      \"quantity\": 1\n    }\n  ],\n  \"subtotal\": 199.99,\n  \"discount\": 0,\n  \"shipping\": 4.99,\n  \"total\": 204.98,\n  \"shippingInfo\": {\n    \"name\": \"Test User\",\n    \"email\": \"testuser@example.com\",\n    \"address\": \"Calle Principal 123\",\n    \"city\": \"Madrid\",\n    \"zip\": \"28001\",\n    \"country\": \"España\"\n  },\n  \"paymentInfo\": {\n    \"cardNumber\": \"4111111111111111\",\n    \"cardName\": \"Test User\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "orders"]
        }
      }
    },
    {
      "name": "Listar pedidos del usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Pedidos listados', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const listSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"orders\", \"totalItems\", \"totalPages\"],",
              "      \"properties\": {",
              "        \"orders\": { \"type\": \"array\", \"minItems\": 1 },",
              "        \"totalItems\": { \"type\": \"number\" },",
              "        \"totalPages\": { \"type\": \"number\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de listado de pedidos es válido', () => {",
              "  pm.expect(tv4.validate(json, listSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders/user",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "orders", "user"]
        }
      }
    },
    {
      "name": "Error: Crear pedido sin token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 - No autorizado', () => { pm.response.to.have.status(401); });",
              "const json = pm.response.json();",
              "const errorSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"message\"],",
              "  \"properties\": {",
              "    \"message\": { \"type\": \"string\", \"enum\": [\"Token no proporcionado\"] }",
              "  }",
              "};",
              "pm.test('El esquema de error 401 es válido', () => {",
              "  pm.expect(tv4.validate(json, errorSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shippingAddress\": {\n    \"street\": \"Calle Principal 123\",\n    \"city\": \"Madrid\",\n    \"state\": \"Madrid\",\n    \"zipCode\": \"28001\",\n    \"country\": \"España\"\n  },\n  \"paymentMethod\": \"card\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "orders"]
        }
      }
    }
  ]
}
