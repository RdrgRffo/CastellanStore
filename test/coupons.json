{
  "info": {
    "name": "CastellanStore - Coupons API",
    "description": "Endpoints de cupones: validar cupón (requiere autenticación)."
  },
  "item": [
    {
      "name": "Validar cupón existente",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Cupón válido', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const couponSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"code\", \"discount\", \"valid\"],",
              "      \"properties\": {",
              "        \"code\": { \"type\": \"string\" },",
              "        \"discount\": { \"type\": \"number\" },",
              "        \"valid\": { \"type\": \"boolean\", \"enum\": [true] }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema del cupón válido es válido', () => {",
              "  pm.expect(tv4.validate(json, couponSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"DESC10\",\n  \"subtotal\": 100\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons/validate",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons", "validate"]
        }
      }
    },
    {
      "name": "Error: Cupón inválido",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Cupón inválido (valid=false)', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const invalidCouponSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"valid\"],",
              "      \"properties\": {",
              "        \"valid\": { \"type\": \"boolean\", \"enum\": [false] }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de cupón inválido es válido', () => {",
              "  pm.expect(tv4.validate(json, invalidCouponSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"CODIGOINVALIDO\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons/validate",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons", "validate"]
        }
      }
    },
    {
      "name": "Error: Validar cupón sin token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 - No autorizado', () => { pm.response.to.have.status(401); });",
              "const json = pm.response.json();",
              "const errorSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"message\"],",
              "  \"properties\": {",
              "    \"message\": { \"type\": \"string\", \"enum\": [\"Token no proporcionado\"] }",
              "  }",
              "};",
              "pm.test('El esquema de error 401 es válido', () => {",
              "  pm.expect(tv4.validate(json, errorSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"WELCOME10\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/coupons/validate",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "coupons", "validate"]
        }
      }
    }
  ]
}
