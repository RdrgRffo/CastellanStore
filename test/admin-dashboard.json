{
  "info": {
    "name": "CastellanStore - Admin Dashboard API",
    "description": "Endpoints del panel de administración: estadísticas y resumen (requiere ROLE_MANAGER)."
  },
  "item": [
    {
      "name": "Obtener dashboard (admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Dashboard obtenido', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const dashboardSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": { \"type\": \"object\" }",
              "  }",
              "};",
              "pm.test('El esquema del dashboard es válido', () => {",
              "  pm.expect(tv4.validate(json, dashboardSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/dashboard",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "dashboard"]
        }
      }
    },
    {
      "name": "Error: Dashboard sin token de admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 - No autorizado', () => { pm.response.to.have.status(401); });",
              "const json = pm.response.json();",
              "const errorSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"message\"],",
              "  \"properties\": {",
              "    \"message\": { \"type\": \"string\", \"enum\": [\"Token no proporcionado\"] }",
              "  }",
              "};",
              "pm.test('El esquema de error 401 es válido', () => {",
              "  pm.expect(tv4.validate(json, errorSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/dashboard",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "dashboard"]
        }
      }
    },
    {
      "name": "Error: Dashboard con token de usuario normal",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 403 - Acceso denegado', () => { pm.response.to.have.status(403); });",
              "const json = pm.response.json();",
              "const errorSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [false] }",
              "  }",
              "};",
              "pm.test('El esquema de error 403 es válido', () => {",
              "  pm.expect(tv4.validate(json, errorSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/dashboard",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "dashboard"]
        }
      }
    }
  ]
}
