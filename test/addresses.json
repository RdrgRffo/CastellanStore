{
  "info": {
    "name": "CastellanStore - Addresses API",
    "description": "Endpoints de direcciones guardadas: crear, listar, obtener, actualizar, eliminar, establecer por defecto (requieren autenticación)."
  },
  "item": [
    {
      "name": "Crear dirección",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 - Dirección creada', () => { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "const createSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"_id\", \"name\", \"isDefault\"],",
              "      \"properties\": {",
              "        \"_id\": { \"type\": \"string\" },",
              "        \"name\": { \"type\": \"string\", \"enum\": [\"Casa\"] },",
              "        \"isDefault\": { \"type\": \"boolean\", \"enum\": [true] }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de dirección creada es válido', () => {",
              "  pm.expect(tv4.validate(json, createSchema)).to.be.true;",
              "});",
              "pm.environment.set('addressId', json.data._id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Casa\",\n  \"fullName\": \"Test User\",\n  \"address\": \"Calle Principal 123\",\n  \"city\": \"Madrid\",\n  \"state\": \"Madrid\",\n  \"zip\": \"28001\",\n  \"country\": \"España\",\n  \"phone\": \"+34911234567\",\n  \"isDefault\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/addresses",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "addresses"]
        }
      }
    },
    {
      "name": "Listar direcciones del usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Direcciones listadas', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const listSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"array\",",
              "      \"minItems\": 1",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de listado de direcciones es válido', () => {",
              "  pm.expect(tv4.validate(json, listSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/addresses",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "addresses"]
        }
      }
    },
    {
      "name": "Obtener dirección por ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Dirección obtenida', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const getSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"_id\"],",
              "      \"properties\": {",
              "        \"_id\": { \"type\": \"string\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de dirección obtenida es válido', () => {",
              "  pm.expect(tv4.validate(json, getSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/addresses/{{addressId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "addresses", "{{addressId}}"]
        }
      }
    },
    {
      "name": "Actualizar dirección",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Dirección actualizada', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const updateSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"name\"],",
              "      \"properties\": {",
              "        \"name\": { \"type\": \"string\", \"enum\": [\"Trabajo\"] }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de dirección actualizada es válido', () => {",
              "  pm.expect(tv4.validate(json, updateSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Trabajo\",\n  \"address\": \"Avenida de la Empresa 456\",\n  \"city\": \"Madrid\",\n  \"zip\": \"28002\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/addresses/{{addressId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "addresses", "{{addressId}}"]
        }
      }
    },
    {
      "name": "Establecer dirección por defecto",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Dirección marcada como default', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const defaultSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"isDefault\"],",
              "      \"properties\": {",
              "        \"isDefault\": { \"type\": \"boolean\", \"enum\": [true] }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de dirección por defecto es válido', () => {",
              "  pm.expect(tv4.validate(json, defaultSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/addresses/{{addressId}}/default",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "addresses", "{{addressId}}", "default"]
        }
      }
    },
    {
      "name": "Eliminar dirección",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Dirección eliminada', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const deleteSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] }",
              "  }",
              "};",
              "pm.test('El esquema de eliminación es válido', () => {",
              "  pm.expect(tv4.validate(json, deleteSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/addresses/{{addressId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "addresses", "{{addressId}}"]
        }
      }
    },
    {
      "name": "Error: Crear dirección sin token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 - No autorizado', () => { pm.response.to.have.status(401); });",
              "const json = pm.response.json();",
              "const errorSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"message\"],",
              "  \"properties\": {",
              "    \"message\": { \"type\": \"string\", \"enum\": [\"Token no proporcionado\"] }",
              "  }",
              "};",
              "pm.test('El esquema de error 401 es válido', () => {",
              "  pm.expect(tv4.validate(json, errorSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"label\": \"Casa\",\n  \"address\": \"Calle Falsa 123\",\n  \"city\": \"Madrid\",\n  \"zip\": \"28001\",\n  \"country\": \"España\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/addresses",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "addresses"]
        }
      }
    }
  ]
}
