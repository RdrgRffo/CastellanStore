{
  "info": {
    "name": "CastellanStore - Reviews API",
    "description": "Endpoints de valoraciones y reseñas: crear, listar, editar, eliminar."
  },
  "item": [
    {
      "name": "Obtener reseñas de un producto (público)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Reseñas obtenidas', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const reviewsSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"data\", \"averageRating\", \"totalReviews\"],",
              "      \"properties\": {",
              "        \"data\": { \"type\": \"array\" },",
              "        \"averageRating\": { \"type\": \"number\" },",
              "        \"totalReviews\": { \"type\": \"number\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de reseñas es válido', () => {",
              "  pm.expect(tv4.validate(json, reviewsSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/reviews/watch/{{watchId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "reviews", "watch", "{{watchId}}"]
        }
      }
    },
    {
      "name": "Crear reseña (autenticado)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (pm.response.code === 201) {",
              "  pm.test('Status 201 - Reseña creada', () => { pm.response.to.have.status(201); });",
              "  const createSchema = {",
              "    \"type\": \"object\",",
              "    \"required\": [\"success\", \"data\"],",
              "    \"properties\": {",
              "      \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "      \"data\": {",
              "        \"type\": \"object\",",
              "        \"required\": [\"rating\"],",
              "        \"properties\": {",
              "          \"rating\": { \"type\": \"number\", \"enum\": [5] }",
              "        }",
              "      }",
              "    }",
              "  };",
              "  pm.test('El esquema de reseña creada es válido', () => {",
              "    pm.expect(tv4.validate(json, createSchema)).to.be.true;",
              "  });",
              "  pm.environment.set('reviewId', json.data._id);",
              "} else {",
              "  pm.test('Status 409 - Reseña ya existe (esperado si ya se creó antes)', () => { pm.response.to.have.status(409); });",
              "  const errorSchema = {",
              "    \"type\": \"object\",",
              "    \"required\": [\"success\"],",
              "    \"properties\": {",
              "      \"success\": { \"type\": \"boolean\", \"enum\": [false] }",
              "    }",
              "  };",
              "  pm.test('El esquema de error 409 es válido', () => {",
              "    pm.expect(tv4.validate(json, errorSchema)).to.be.true;",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"watchId\": \"{{watchId}}\",\n  \"rating\": 5,\n  \"title\": \"Excelente reloj\",\n  \"comment\": \"Muy buena calidad y diseño elegante. Lo recomiendo totalmente.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/reviews",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "reviews"]
        }
      }
    },
    {
      "name": "Obtener reseñas del usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Reseñas del usuario', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const myReviewsSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": { \"type\": \"array\" }",
              "  }",
              "};",
              "pm.test('El esquema de reseñas del usuario es válido', () => {",
              "  pm.expect(tv4.validate(json, myReviewsSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/reviews/my-reviews",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "reviews", "my-reviews"]
        }
      }
    },
    {
      "name": "Error: Crear reseña sin autenticación",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 - No autorizado', () => { pm.response.to.have.status(401); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"watchId\": \"{{watchId}}\",\n  \"rating\": 4,\n  \"title\": \"Test\",\n  \"comment\": \"Test\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/reviews",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "reviews"]
        }
      }
    }
  ]
}
