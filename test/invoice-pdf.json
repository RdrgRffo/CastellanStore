{
  "info": {
    "name": "CastellanStore - Invoice PDF API",
    "description": "Endpoints de facturación: obtener datos de factura y descargar PDF."
  },
  "item": [
    {
      "name": "Obtener datos de factura por orderNumber",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Factura obtenida', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Respuesta contiene datos de factura', () => {",
              "  pm.expect(json.success).to.be.true;",
              "  pm.expect(json.data.invoiceNumber).to.be.a('string');",
              "  pm.expect(json.data.invoiceNumber).to.match(/^FACT-/);",
              "  pm.expect(json.data.status).to.eql('issued');",
              "  pm.expect(json.data).to.have.property('subtotal');",
              "  pm.expect(json.data).to.have.property('taxAmount');",
              "  pm.expect(json.data).to.have.property('total');",
              "  pm.expect(json.data).to.have.property('items');",
              "  pm.expect(json.data.items).to.be.an('array');",
              "  pm.environment.set('invoiceNumber', json.data.invoiceNumber);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/invoices/{{orderNumber}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "invoices", "{{orderNumber}}"]
        }
      }
    },
    {
      "name": "Descargar PDF de factura",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - PDF descargado', () => { pm.response.to.have.status(200); });",
              "pm.test('Content-Type es application/pdf', () => {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf');",
              "});",
              "pm.test('Content-Disposition incluye nombre de archivo', () => {",
              "  const cd = pm.response.headers.get('Content-Disposition');",
              "  pm.expect(cd).to.include('attachment');",
              "  pm.expect(cd).to.include('.pdf');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/invoices/{{orderNumber}}/pdf",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "invoices", "{{orderNumber}}", "pdf"]
        }
      }
    },
    {
      "name": "Error: Factura de orderNumber inexistente",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404 - Factura no encontrada', () => { pm.response.to.have.status(404); });",
              "const json = pm.response.json();",
              "pm.test('Mensaje de error', () => {",
              "  pm.expect(json.success).to.be.false;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/invoices/INEXISTENTE-999999",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "invoices", "INEXISTENTE-999999"]
        }
      }
    }
  ]
}
