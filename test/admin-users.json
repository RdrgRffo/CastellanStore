{
  "info": {
    "name": "CastellanStore - Admin Users API",
    "description": "Endpoints de administración de usuarios: listar, buscar, cambiar rol, bloquear (requiere ROLE_MANAGER)."
  },
  "item": [
    {
      "name": "Listar usuarios (admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Usuarios listados', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const listSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"users\", \"totalItems\", \"totalPages\"],",
              "      \"properties\": {",
              "        \"users\": { \"type\": \"array\", \"minItems\": 1 },",
              "        \"totalItems\": { \"type\": \"number\" },",
              "        \"totalPages\": { \"type\": \"number\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de listado de usuarios admin es válido', () => {",
              "  pm.expect(tv4.validate(json, listSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/users",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "users"]
        }
      }
    },
    {
      "name": "Buscar usuarios por email (admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Búsqueda exitosa', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const searchSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"users\"],",
              "      \"properties\": {",
              "        \"users\": { \"type\": \"array\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de búsqueda de usuarios es válido', () => {",
              "  pm.expect(tv4.validate(json, searchSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/users?search=test",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "users"],
          "query": [
            { "key": "search", "value": "test" }
          ]
        }
      }
    },
    {
      "name": "Cambiar rol de usuario (admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200/409/401/404 - Rol actualizado', () => { pm.expect(pm.response.code).to.be.oneOf([200, 401, 404, 409]); });",
              "const json = pm.response.json();",
              "if (pm.response.code === 200 || pm.response.code === 409) {",
              "  const roleSchema = {",
              "    \"type\": \"object\",",
              "    \"required\": [\"success\", \"data\"],",
              "    \"properties\": {",
              "      \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "      \"data\": {",
              "        \"type\": \"object\",",
              "        \"required\": [\"role\"],",
              "        \"properties\": {",
              "          \"role\": { \"type\": \"string\", \"enum\": [\"ROLE_USER\"] }",
              "        }",
              "      }",
              "    }",
              "  };",
              "  pm.test('El esquema de cambio de rol es válido', () => {",
              "    pm.expect(tv4.validate(json, roleSchema)).to.be.true;",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"ROLE_USER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}/role",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "users", "{{userId}}", "role"]
        }
      }
    },
    {
      "name": "Bloquear usuario (admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200/409/401/404 - Usuario bloqueado/desbloqueado', () => { pm.expect(pm.response.code).to.be.oneOf([200, 401, 404, 409]); });",
              "const json = pm.response.json();",
              "if (pm.response.code === 200 || pm.response.code === 409) {",
              "  const blockSchema = {",
              "    \"type\": \"object\",",
              "    \"required\": [\"success\", \"data\"],",
              "    \"properties\": {",
              "      \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "      \"data\": {",
              "        \"type\": \"object\",",
              "        \"required\": [\"blocked\"],",
              "        \"properties\": {",
              "          \"blocked\": { \"type\": \"boolean\" }",
              "        }",
              "      }",
              "    }",
              "  };",
              "  pm.test('El esquema de bloqueo de usuario es válido', () => {",
              "    pm.expect(tv4.validate(json, blockSchema)).to.be.true;",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}/block",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "users", "{{userId}}", "block"]
        }
      }
    },
    {
      "name": "Error: Listar usuarios sin token de admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 - No autorizado', () => { pm.response.to.have.status(401); });",
              "const json = pm.response.json();",
              "const errorSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"message\"],",
              "  \"properties\": {",
              "    \"message\": { \"type\": \"string\", \"enum\": [\"Token no proporcionado\"] }",
              "  }",
              "};",
              "pm.test('El esquema de error 401 es válido', () => {",
              "  pm.expect(tv4.validate(json, errorSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/users",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "users"]
        }
      }
    }
  ]
}
