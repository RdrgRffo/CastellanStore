              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"token\", \"user\"],",
              "      \"properties\": {",
              "        \"token\": { \"type\": \"string\" },",
              "        \"user\": {",
              "          \"type\": \"object\",",
              "          \"required\": [\"role\"],",
              "          \"properties\": {",
              "            \"role\": { \"type\": \"string\", \"enum\": [\"ROLE_USER\"] }",
              "          }",
              "        }",
              "      }",
              "    }",
              "  }",
              "};",
