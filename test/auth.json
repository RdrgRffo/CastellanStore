    },
    {
      "name": "Obtener perfil (protegido)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Perfil obtenido', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const profileSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"email\"],",
              "      \"properties\": {",
              "        \"email\": { \"type\": \"string\", \"pattern\": \".*@.*\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema del perfil es válido', () => {",
              "  pm.expect(tv4.validate(json, profileSchema)).to.be.true;",
              "});",
              "pm.expect(json.data.email).to.eql(pm.environment.get('userEmail'));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/profile",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "profile"]
        }
      }
    },
    {
      "name": "Actualizar perfil (protegido)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Perfil actualizado', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const updateSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"birthDate\"],",
              "      \"properties\": {",
              "        \"birthDate\": { \"type\": \"string\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de actualización es válido', () => {",
              "  pm.expect(tv4.validate(json, updateSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"birthDate\": \"1990-05-15\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/profile",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "profile"]
        }
      }
    },
