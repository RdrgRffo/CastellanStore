{
  "info": {
    "name": "CastellanStore - Auth API",
    "description": "Endpoints de autenticación: registro, login, Google OAuth, perfil. Gestiona tokens de usuario normal y administrador."
  },
  "item": [
    {
      "name": "Registrar usuario normal",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (pm.response.code === 201) {",
              "  pm.test('Status 201 - Usuario creado', () => { pm.response.to.have.status(201); });",
              "  const registerSchema = {",
              "    \"type\": \"object\",",
              "    \"required\": [\"success\", \"data\"],",
              "    \"properties\": {",
              "      \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "      \"data\": {",
              "        \"type\": \"object\",",
              "        \"required\": [\"token\", \"user\"],",
              "        \"properties\": {",
              "          \"token\": { \"type\": \"string\" },",
              "          \"user\": {",
              "            \"type\": \"object\",",
              "            \"required\": [\"id\", \"role\"],",
              "            \"properties\": {",
              "              \"id\": { \"type\": \"string\" },",
              "              \"role\": { \"type\": \"string\", \"enum\": [\"ROLE_USER\"] }",
              "            }",
              "          }",
              "        }",
              "      }",
              "    }",
              "  };",
              "  pm.test('El esquema de registro es válido', () => {",
              "    pm.expect(tv4.validate(json, registerSchema)).to.be.true;",
              "  });",
              "  pm.environment.set('userToken', json.data.token);",
              "  pm.environment.set('userId', json.data.user.id);",
              "} else {",
              "  pm.test('Status 400/409 - Registro', () => { pm.expect(pm.response.code).to.be.oneOf([400, 409]); });",
              "  const errorSchema = {",
              "    \"type\": \"object\",",
              "    \"required\": [\"success\"],",
              "    \"properties\": {",
              "      \"success\": { \"type\": \"boolean\", \"enum\": [false] }",
              "    }",
              "  };",
              "  pm.test('El esquema de error es válido', () => {",
              "    pm.expect(tv4.validate(json, errorSchema)).to.be.true;",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"birthDate\": \"{{userBirthDate}}\",\n  \"name\": \"{{userName}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "register"]
        }
      }
    },
    {
      "name": "Login como administrador",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200/401 - Login admin', () => { pm.expect(pm.response.code).to.be.oneOf([200, 401]); });",
              "const json = pm.response.json();",
              "const loginSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"token\", \"user\"],",
              "      \"properties\": {",
              "        \"token\": { \"type\": \"string\" },",
              "        \"user\": {",
              "          \"type\": \"object\",",
              "          \"required\": [\"role\"],",
              "          \"properties\": {",
              "            \"role\": { \"type\": \"string\", \"enum\": [\"ROLE_MANAGER\"] }",
              "          }",
              "        }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de login admin es válido', () => {",
              "  pm.expect(tv4.validate(json, loginSchema)).to.be.true;",
              "});",
              "pm.environment.set('adminToken', json.data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
