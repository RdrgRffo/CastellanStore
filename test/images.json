{
  "info": {
    "name": "CastellanStore - Images API",
    "description": "Endpoints de imágenes: servir imágenes por nombre de archivo (público)."
  },
  "item": [
    {
      "name": "Obtener imagen por nombre de archivo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Imagen obtenida', () => { pm.response.to.have.status(200); });",
              "pm.test('Content-Type es imagen', () => {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('image/');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/images/{{watchId}}.webp",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "images", "{{watchId}}.webp"]
        }
      }
    },
    {
      "name": "Error: Imagen no encontrada",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404 - Imagen no encontrada', () => { pm.response.to.have.status(404); });",
              "const json = pm.response.json();",
              "pm.test('Mensaje de error', () => {",
              "  pm.expect(json.error).to.eql('Imagen no encontrada');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/images/no-existe.png",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "images", "no-existe.png"]
        }
      }
    }
  ]
}
