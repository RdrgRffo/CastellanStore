{
  "info": {
    "name": "CastellanStore - Wishlist API",
    "description": "Endpoints de lista de deseos: añadir, listar, eliminar, comprobar."
  },
  "item": [
    {
      "name": "Añadir a wishlist (autenticado)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Añadido a wishlist', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const addSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"items\"],",
              "      \"properties\": {",
              "        \"items\": { \"type\": \"array\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de añadir a wishlist es válido', () => {",
              "  pm.expect(tv4.validate(json, addSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"watchId\": \"{{watchId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/wishlist",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "wishlist"]
        }
      }
    },
    {
      "name": "Comprobar si está en wishlist",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Comprobado', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const checkSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"inWishlist\"],",
              "      \"properties\": {",
              "        \"inWishlist\": { \"type\": \"boolean\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de comprobación es válido', () => {",
              "  pm.expect(tv4.validate(json, checkSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/wishlist/check/{{watchId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "wishlist", "check", "{{watchId}}"]
        }
      }
    },
    {
      "name": "Obtener wishlist",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Wishlist obtenida', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const listSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\", \"data\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] },",
              "    \"data\": {",
              "      \"type\": \"object\",",
              "      \"required\": [\"items\"],",
              "      \"properties\": {",
              "        \"items\": { \"type\": \"array\" }",
              "      }",
              "    }",
              "  }",
              "};",
              "pm.test('El esquema de listado de wishlist es válido', () => {",
              "  pm.expect(tv4.validate(json, listSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/wishlist",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "wishlist"]
        }
      }
    },
    {
      "name": "Eliminar de wishlist",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 - Eliminado de wishlist', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "const deleteSchema = {",
              "  \"type\": \"object\",",
              "  \"required\": [\"success\"],",
              "  \"properties\": {",
              "    \"success\": { \"type\": \"boolean\", \"enum\": [true] }",
              "  }",
              "};",
              "pm.test('El esquema de eliminación es válido', () => {",
              "  pm.expect(tv4.validate(json, deleteSchema)).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/wishlist/{{watchId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "wishlist", "{{watchId}}"]
        }
      }
    },
    {
      "name": "Error: Wishlist sin autenticación",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 - No autorizado', () => { pm.response.to.have.status(401); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/wishlist",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "wishlist"]
        }
      }
    }
  ]
}
