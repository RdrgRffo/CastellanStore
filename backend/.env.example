# ============================================
# CastellanStore — Backend (Express + TypeScript)
# ============================================

# Puerto del servidor
PORT=9100

# Conexión a MongoDB
MONGODB_URI=mongodb://localhost:27017/castellanstore

# JWT — Secreto para firmar tokens (cambiar en producción)
JWT_SECRET=tu_jwt_secreto_super_seguro_cambiar_en_produccion

# Google OAuth2 — Credenciales
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# ============================================
# Resend — Email transaccional
# ============================================
# Obtener API Key en: https://resend.com/api-keys
# Ejemplo:
#   RESEND_API_KEY=re_xxxxxxxxxxxx
#   RESEND_FROM=Castellan Store <no-reply@tudominio.com>
#
# ⚠️ Resend solo permite enviar desde dominios verificados.
# Si usas un dominio no verificado, el email se simulará en consola.
# Para desarrollo, puedes usar el dominio animalwatch.es que ya está verificado:
#   RESEND_FROM=Castellan Store <noreply@animalwatch.es>
#
# Si no se configuran, los emails se simularán en consola.
# RESEND_API_KEY=
# RESEND_FROM=

# ============================================
# MinIO — Almacenamiento S3 (imágenes)
# ============================================
# Endpoint interno de MinIO (dentro de Docker)
MINIO_ENDPOINT=http://minio:9000
# URL pública para acceder a las imágenes desde el frontend
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=castellan-images

# ============================================
# Stripe — Pasarela de pago
# ============================================
# Obtener en: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# (Opcional) Para probar webhooks localmente: stripe listen --forward-to localhost:9100/api/v1/payments/webhook
